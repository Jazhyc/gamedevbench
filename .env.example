# GameDevBench Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# API Keys (Required - depends on agent used)
# ============================================

# For claude-code agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For codex agent and some openhands models
OPENAI_API_KEY=your_openai_api_key_here

# For gemini-cli agent
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative variable name (either works)
# GOOGLE_API_KEY=your_google_api_key_here

# For openhands agent (via OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For openhands agent (via DeepSeek's native API, e.g. --model deepseek-v4-pro
# or any deepseek/<model>). Note: DeepSeek models are text-only, so the
# screenshot MCP path (--enable-mcp) won't work with them.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# For openhands agent (via Fireworks)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ============================================
# Optional Configuration
# ============================================

# OpenRouter configuration (optional for openhands)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=your_site_url
OR_APP_NAME=your_app_name

# Godot configuration (optional)
# Path to Godot executable if not in PATH
# GODOT_EXEC_PATH=godot

# MCP Server configuration (cross-platform: Windows / macOS / Linux via mss)
# Monitor to capture for screenshots, 1-indexed: 1 = primary, 2 = second, ...
# Out-of-range values fall back to the primary monitor, so 1 is safe for a
# single-monitor machine.
GODOT_SCREENSHOT_DISPLAY=1
